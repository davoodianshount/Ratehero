{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bolt-proxy",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-12",
  "observability": {
    "enabled": true
  },

  // D1 database for conversation logging. IDs populated at deploy time by
  // .github/workflows/deploy-bolt-proxy.yml (resolved from `wrangler d1 list`).
  "d1_databases": [
    {
      "binding": "BOLT_DB",
      "database_name": "bolt-data",
      "database_id": "d872842e-62db-4fa1-9d56-86a656946e45"
    }
  ],

  // KV namespace for editable system prompt + alert webhook URL.
  "kv_namespaces": [
    {
      "binding": "BOLT_CONFIG",
      "id": "083d29dd347748c6ad1139b58e2003b9"
    }
  ]
}
